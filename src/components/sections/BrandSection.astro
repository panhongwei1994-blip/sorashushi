---
import { getContent, normalizeLocale } from "@/data/site";

const lang = normalizeLocale(Astro.props.lang);
const content = getContent(lang);
---

<section id="menu" class="container menu-intro">
  <div class="menu-intro-grid">
    <div class="menu-copy">
      <p class="eyebrow">{content.menuEyebrow}</p>
      <h2 class="section-title">{content.menuTitle}</h2>
      <p class="section-copy menu-copy-text">
        {content.menuBody}
      </p>
    </div>
  </div>
</section>

<style>
  .menu-intro {
    padding: 88px 0 24px;
  }
  .menu-intro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    align-items: start;
  }
  .menu-copy {
    max-width: 50rem;
  }
  .menu-copy-text {
    max-width: 42rem;
    margin-top: 20px;
  }
  @media (max-width: 900px) {
    .menu-intro-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
