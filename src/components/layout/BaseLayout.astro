---
import "@/styles/global.css";
import { getContent, getLocaleUrls, getRestaurantSchema, normalizeLocale } from "@/data/site";

interface Props {
  lang?: string;
}

const lang = normalizeLocale(Astro.props.lang);
const content = getContent(lang);
const localeUrls = getLocaleUrls(lang);
const schema = getRestaurantSchema(lang);
const canonical = lang === "en" ? "/" : `/${lang}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{content.metaTitle}</title>
    <meta name="description" content={content.metaDescription} />
    <meta property="og:title" content={content.metaTitle} />
    <meta property="og:description" content={content.metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/sushi/hero.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.metaTitle} />
    <meta name="twitter:description" content={content.metaDescription} />
    <meta name="theme-color" content="#07080c" />
    <link rel="canonical" href={canonical} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-shell card">
        <a href={lang === "en" ? "/" : `/${lang}`} class="brand-mark">
          {content.brand}
        </a>
        <nav class="locale-nav">
          {localeUrls.map((item) => (
            <a
              href={item.url}
              class:list={["locale-link", { active: item.active }]}
            >
              {item.locale}
            </a>
          ))}
        </nav>
        <div class="header-actions">
          <a href="#menu" class="header-ghost">Menu</a>
          <a href="#order-menu" class="header-order">{content.orderNow}</a>
        </div>
      </div>
    </header>
    <slot />
  </body>
</html>

<style>
  .site-header {
    position: fixed;
    inset: 16px 16px auto;
    z-index: 30;
  }
  .header-shell {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 999px;
    backdrop-filter: blur(18px);
    background:
      linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.022)),
      rgba(8,10,16,.72);
  }
  .brand-mark,
  .locale-link,
  .header-order,
  .header-ghost {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .22em;
    text-transform: uppercase;
  }
  .brand-mark {
    white-space: nowrap;
  }
  .locale-nav,
  .header-actions {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .locale-nav {
    justify-content: center;
  }
  .locale-link,
  .header-ghost {
    padding: 8px 12px;
    border-radius: 999px;
    color: rgba(246,239,230,.68);
  }
  .locale-link.active {
    background: rgba(212,165,74,.18);
    color: #f4d59a;
  }
  .header-ghost {
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.03);
  }
  .header-order {
    padding: 10px 15px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--gold), var(--gold-soft));
    color: #160f08;
  }
  @media (max-width: 860px) {
    .header-shell {
      grid-template-columns: 1fr;
      justify-items: start;
      border-radius: 28px;
    }
    .locale-nav {
      justify-content: flex-start;
    }
  }
</style>
